From: mechanic-Q
Date: 2026-06-16
Subject: [PATCH] Hermes mem0 plugin — pass host from mem0.json to MemoryClient

Without this patch, the Hermes mem0 plugin always connects to the official
Mem0 cloud API (https://api.mem0.ai) because _get_client() does not forward
the "host" setting from ~/.hermes/mem0.json to MemoryClient().

This adds:
1. self._host field initialized to ""
2. self._host read from mem0.json host in initialize()
3. Conditional pass of host kwarg to MemoryClient()


--- a/plugins/memory/mem0/__init__.py
+++ b/plugins/memory/mem0/__init__.py
@@ -127,6 +127,7 @@
         self._user_id = "hermes-user"
         self._agent_id = "hermes"
         self._rerank = True
+        self._host = ""
         self._prefetch_result = ""
         self._prefetch_lock = threading.Lock()
         self._prefetch_thread = None
@@ -173,7 +174,10 @@
                 return self._client
             try:
                 from mem0 import MemoryClient
-                self._client = MemoryClient(api_key=self._api_key)
+                kwargs = {"api_key": self._api_key}
+                if self._host:
+                    kwargs["host"] = self._host
+                self._client = MemoryClient(**kwargs)
                 return self._client
             except ImportError:
                 raise RuntimeError("mem0 package not installed. Run: pip install mem0ai")
@@ -209,6 +213,7 @@
         self._user_id = kwargs.get("user_id") or self._config.get("user_id", "hermes-user")
         self._agent_id = self._config.get("agent_id", "hermes")
         self._rerank = self._config.get("rerank", True)
+        self._host = self._config.get("host", "")
 
     def _read_filters(self) -> Dict[str, Any]:
         """Filters for search/get_all — scoped to user only for cross-session recall."""
