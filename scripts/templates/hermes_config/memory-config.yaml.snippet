# Hermes mem0 本地化 - memory 段片段
# 用法: bash scripts/apply-hermes-config.sh
#
# 这个片段会被 append 到 ~/.hermes/config.yaml 的 "memory:" 段。
# 如果 "memory:" 段已存在，存在则覆盖；不存在则追加。
#
# 注意: 不要在本文件加 api_key。Hermes mem0 插件会自动从 env 或 ~/.hermes/mem0.json 读 host。

memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 2200
  user_char_limit: 1375
  provider: mem0
  flush_min_turns: 6
  nudge_interval: 10
  base_url: http://localhost:8050
